# Copy to .env and fill in the providers you plan to use.
# The launcher (skillfl.skillflow_adapter.cli and iterative_shared_skills_runner.py)
# reads these via environment-variable interpolation in the YAML configs.

# Dashscope — used by qwen3.6-plus and glm-5 workers (and the cloud-skill merger).
# Anthropic-compatible endpoint: https://dashscope.aliyuncs.com/apps/anthropic
# OpenAI-compatible endpoint:    https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_KEY=

# Moonshot — used by kimi-k2.5 workers.
# Anthropic-compatible endpoint: https://api.moonshot.ai/anthropic
# OpenAI-compatible endpoint:    https://api.moonshot.ai/v1
MOONSHOT_KEY=

# Anthropic — only needed if you point a worker or the merger at Anthropic's
# native endpoint instead of one of the gateways above.
ANTHROPIC_API_KEY=
